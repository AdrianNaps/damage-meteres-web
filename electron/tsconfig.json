{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "ignoreDeprecations": "6.0",
    "outDir": "../dist-electron",
    "rootDir": "..",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts", "../server/**/*.ts"],
  "exclude": [
    "./preload.cjs",
    "../server/stateMachine.test.ts",
    "../server/index.ts"
  ]
}
